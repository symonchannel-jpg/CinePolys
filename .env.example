# PostgreSQL (Vercel / Producción)
# Obtén tu URL en: https://vercel.com/dashboard → Storage → Postgres
# O usa Neon: https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/cinepolis?schema=public"

# NextAuth
# Genera un secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

