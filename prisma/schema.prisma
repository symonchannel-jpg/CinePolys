generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOD
  CREW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VFXStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  APPROVED
  REJECTED
}

enum VFXComplexity {
  LOW
  MEDIUM
  HIGH
}

enum ScriptStatus {
  DRAFT
  IN_REVIEW
  LOCKED
  IN_PRODUCTION
  ARCHIVED
}

enum ScriptType {
  LITERARY
  TECHNICAL
  NARRATIVE
}

enum BreakdownCategory {
  CHARACTER
  PROP
  WARDROBE
  LOCATION
  VEHICLE
  SFX
  VFX
  EXTRA
  OTHER
}

enum BreakdownStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         Role      @default(CREW)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean   @default(false)
  currentProjectId String?
  projectOrder Json?
  avatarIcon   String?   @default("User")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?

  createdTasks  Task[]         @relation("TaskCreator")
  comments      Comment[]
  callSheets    CallSheet[]
  activities    ActivityLog[]
  notifications Notification[]
  taskAssignments TaskAssignment[]
  vfxShots      VFXShot[]
  scriptVersions ScriptVersion[]
  breakdownItems ScriptBreakdownItem[]
  postScreeningNotes PostScreeningNote[]
  postDeliverables   PostDeliverable[]
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  users User[]
  tasks Task[]
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String?   @default("🎬")
  color       String?   @default("#3b82f6")
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  tasks      Task[]
  scripts    Script[]
  locations  Location[]
  callSheets CallSheet[]
  casting    CastingMember[]
  vfxShots   VFXShot[]
  postCuts        PostCut[]
  postADRs        PostADR[]
  postDeliverables PostDeliverable[]
  activities      ActivityLog[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  priority     Priority   @default(MEDIUM)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project?   @relation(fields: [projectId], references: [id])
  createdById  String
  createdBy    User       @relation("TaskCreator", fields: [createdById], references: [id])
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  archivedAt   DateTime?

  comments     Comment[]
  activities   ActivityLog[]
  assignments  TaskAssignment[]
  scriptItems  ScriptBreakdownItem[]

  @@index([projectId, archivedAt, status])
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Script {
  id            String         @id @default(cuid())
  title         String
  type          ScriptType     @default(LITERARY)
  status        ScriptStatus   @default(DRAFT)
  pageCount     Int            @default(0)
  colorRevision String?
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  uploadedAt    DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  archivedAt    DateTime?

  versions      ScriptVersion[]
  breakdown     ScriptBreakdownItem[]
  activities    ActivityLog[]

  @@index([projectId, archivedAt])
}

model ScriptVersion {
  id           String   @id @default(cuid())
  scriptId     String
  script       Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  version      Int
  filePath     String
  fileName     String
  fileSize     Int
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  notes        String?
  createdAt    DateTime @default(now())
  archivedAt   DateTime?
}

model ScriptBreakdownItem {
  id           String            @id @default(cuid())
  scriptId     String
  script       Script            @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  scene        String?
  page         Int?
  category     BreakdownCategory @default(OTHER)
  title        String
  description  String?
  status       BreakdownStatus   @default(PENDING)
  assignedToId String?
  assignedTo   User?             @relation(fields: [assignedToId], references: [id])
  linkedId     String?
  linkedType   String?
  notes        String?
  taskId       String?
  task         Task?             @relation(fields: [taskId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  archivedAt   DateTime?
}

model Location {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  lat         Float?
  lng         Float?
  images      Json
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  archivedAt  DateTime?

  activities  ActivityLog[]

  @@index([projectId, archivedAt])
}

model CastingMember {
  id              String    @id @default(cuid())
  name            String
  character       String?
  contact         String?
  notes           String?
  profilePhotoUrl String?
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?

  activities      ActivityLog[]
  postADRs        PostADR[]

  @@index([projectId, archivedAt])
}

model ActivityLog {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  taskId       String?
  task         Task?    @relation(fields: [taskId], references: [id])
  scriptId     String?
  script       Script?  @relation(fields: [scriptId], references: [id])
  castingId    String?
  casting      CastingMember? @relation(fields: [castingId], references: [id])
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  vfxShotId    String?
  vfxShot      VFXShot? @relation(fields: [vfxShotId], references: [id])
  callSheetId  String?
  callSheet    CallSheet? @relation(fields: [callSheetId], references: [id])
  action       String
  details      String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([projectId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String
  message   String?
  type      String    @default("info")
  link      String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, read])
}

model CallSheet {
  id          String   @id @default(cuid())
  date        DateTime
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  content     Json
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  archivedAt  DateTime?

  activities  ActivityLog[]
}

model VFXShot {
  id           String        @id @default(cuid())
  shotId       String
  description  String?
  status       VFXStatus     @default(PENDING)
  complexity   VFXComplexity @default(MEDIUM)
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id])
  notes        String?
  version      Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  archivedAt   DateTime?

  activities   ActivityLog[]

  @@index([projectId, archivedAt, status])
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  QC_FAILED
  APPROVED
  REJECTED
}

enum CutStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
  ARCHIVED
}

model PostCut {
  id          String      @id @default(cuid())
  name        String
  version     Int         @default(1)
  status      CutStatus   @default(DRAFT)
  videoUrl    String?
  notes       String?
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivedAt  DateTime?

  screeningNotes PostScreeningNote[]
}

model PostScreeningNote {
  id          String    @id @default(cuid())
  cutId       String
  cut         PostCut   @relation(fields: [cutId], references: [id], onDelete: Cascade)
  timecode    String
  content     String
  category    String
  status      String    @default("PENDING")
  taskId      String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PostADR {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  castingMemberId String
  castingMember   CastingMember @relation(fields: [castingMemberId], references: [id], onDelete: Cascade)
  scene           String?
  line            String
  status          String        @default("PENDING")
  notes           String?
  taskId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  archivedAt      DateTime?
}

model PostDeliverable {
  id           String             @id @default(cuid())
  projectId    String
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  type         String             @default("MASTER")
  status       DeliverableStatus  @default(PENDING)
  notes        String?
  assignedToId String?
  assignedTo   User?              @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  archivedAt   DateTime?
}
